{
  "name": "doppel",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:renderer",
    "dev:renderer": "vite",
    "dev:main": "wait-on http-get://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:electron": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:main\"",
    "build": "vite build",
    "build:renderer": "vite build",
    "build:electron": "pnpm build:renderer && electron-builder --mac --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.doppel.app",
    "productName": "Doppel",
    "icon": "icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "icon.png"
    ],
    "mac": {
      "icon": "icon.png",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@dnd-kit/react": "^0.3.2",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@tailwindcss/vite": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller"
    ]
  }
}
